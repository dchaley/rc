# Aliases specifically for Mac-like unixen

# intellij
alias idea="/Applications/IntelliJ\ IDEA.app/Contents/MacOS/idea"

# OpenJDK said to do this
export CPPFLAGS="-I/opt/homebrew/opt/openjdk/include"

export LDFLAGS="$LDFLAGS -L/opt/homebrew/opt/libpq/lib"
export CPPFLAGS="$CPPFLAGS -I/opt/homebrew/opt/libpq/include"
export PKG_CONFIG_PATH="/opt/homebrew/opt/libpq/lib/pkgconfig:$PKG_CONFIG_PATH"

# Put some brews first on path
# There's gotta be a better way to do this ...?
export PATH=/opt/homebrew/bin:/opt/homebrew/opt/coreutils/libexec/gnubin:/opt/homebrew/opt/grep/libexec/gnubin:/opt/homebrew/opt/postgresql@15/bin:$PATH
export PATH="/usr/local/opt/bison/bin:$PATH"
